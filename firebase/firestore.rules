rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function hasProfile() {
      return isSignedIn() && userDoc().data != null;
    }

    function hasDairyAccess(dairyId) {
      return hasProfile() && userDoc().data.dairyId == dairyId;
    }

    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /dairies/{dairyId} {
      allow read, write: if hasDairyAccess(dairyId);
      match /{document=**} {
        allow read: if hasDairyAccess(dairyId);
        allow write: if hasDairyAccess(dairyId);
      }
    }
  }
}
