rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function hasDairyAccess(dairyId) {
      return isSignedIn() && request.auth.token.dairyId == dairyId;
    }

    function isOwnerOrAdmin() {
      return isSignedIn() &&
        (request.auth.token.role == 'owner' || request.auth.token.role == 'admin');
    }

    match /dairies/{dairyId} {
      allow read: if hasDairyAccess(dairyId);
      allow write: if isOwnerOrAdmin() && hasDairyAccess(dairyId);

      match /{document=**} {
        allow read: if hasDairyAccess(dairyId);
        allow write: if isOwnerOrAdmin() && hasDairyAccess(dairyId);
      }
    }
  }
}
